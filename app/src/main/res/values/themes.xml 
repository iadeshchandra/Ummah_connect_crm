<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Application Theme -->
    <style name="Theme.UmmahConnect" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/islamic_green</item>
        <item name="colorPrimaryDark">@color/islamic_green_dark</item>
        <item name="colorPrimaryContainer">@color/islamic_green_light</item>
        
        <!-- Secondary Colors (Gold) -->
        <item name="colorSecondary">@color/islamic_gold</item>
        <item name="colorSecondaryContainer">@color/islamic_gold_light</item>
        
        <!-- Tertiary Colors (Blue) -->
        <item name="colorTertiary">@color/islamic_blue</item>
        <item name="colorTertiaryContainer">@color/islamic_blue_light</item>
        
        <!-- Background -->
        <item name="android:colorBackground">@color/cream_background</item>
        <item name="colorSurface">@color/off_white</item>
        
        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/islamic_green_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.UmmahConnect.Headline</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.UmmahConnect.Title</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.UmmahConnect.Body</item>
        
        <!-- Components -->
        <item name="materialButtonStyle">@style/Widget.UmmahConnect.Button</item>
        <item name="textInputStyle">@style/Widget.UmmahConnect.TextInput</item>
        <item name="cardViewStyle">@style/Widget.UmmahConnect.Card</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.UmmahConnect.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/islamic_green</item>
        <item name="android:navigationBarColor">@color/islamic_green</item>
    </style>

    <!-- Typography Styles -->
    <style name="TextAppearance.UmmahConnect.Headline" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/islamic_green</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.UmmahConnect.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.UmmahConnect.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.UmmahConnect.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/islamic_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Gold Button Variant -->
    <style name="Widget.UmmahConnect.Button.Gold" parent="Widget.UmmahConnect.Button">
        <item name="backgroundTint">@color/islamic_gold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Text Input Style -->
    <style name="Widget.UmmahConnect.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/islamic_green</item>
        <item name="hintTextColor">@color/islamic_green</item>
        <item name="cursorColor">@color/islamic_green</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.UmmahConnect.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Toolbar Style -->
    <style name="Widget.UmmahConnect.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/islamic_green</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">@color/islamic_gold_light</item>
    </style>
</resources>
